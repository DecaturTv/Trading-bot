# Trading mode gate — both must be set explicitly to trade live
TRADING_MODE=paper
I_UNDERSTAND_LIVE_RISK=false

# Alpaca (options paper phase)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Schwab (options live phase, later)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# OANDA (forex, later)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# Infra
DATABASE_URL=postgresql://trading_bot:trading_bot@localhost:5432/trading_bot
REDIS_URL=redis://localhost:6379/0

# Account & risk
ACCOUNT_START_BALANCE=500
CONFIDENCE_THRESHOLD=92
KELLY_FRACTION=0.25
DAILY_LOSS_LIMIT_PCT=0.05
WEEKLY_LOSS_LIMIT_PCT=0.10

# Alerts (all optional — a channel is only wired up if its fields are present)
DISCORD_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
