# Trading mode gate — both must be set explicitly to trade live
TRADING_MODE=paper
I_UNDERSTAND_LIVE_RISK=false

# Alpaca (options paper phase)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Schwab (options live phase, later)
SCHWAB_CLIENT_ID=
SCHWAB_CLIENT_SECRET=

# OANDA (forex) — opt-in: forex trading only starts if both are set.
# Uses OANDA's practice endpoint while TRADING_MODE=paper, live endpoint
# when TRADING_MODE=live.
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# Infra
DATABASE_URL=postgresql://trading_bot:trading_bot@localhost:5432/trading_bot
REDIS_URL=redis://localhost:6379/0

# Account & risk
ACCOUNT_START_BALANCE=500
CONFIDENCE_THRESHOLD=92
KELLY_FRACTION=0.25
DAILY_LOSS_LIMIT_PCT=0.05
WEEKLY_LOSS_LIMIT_PCT=0.10

# Alerts (all optional — a channel is only wired up if its fields are present)
DISCORD_WEBHOOK_URL=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBER=

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# ML tracking
MLFLOW_TRACKING_URI=sqlite:///mlruns/mlflow.db

# Trade management (confirmed project rules)
STOP_LOSS_PCT=0.50
PROFIT_TARGET_PCT=1.00
SCALE_OUT_FRACTION=0.50
TRAILING_STOP_PCT=0.20
MIN_TRADING_DAYS_BEFORE_EXPIRY=2

# Option selection for the live entry loop
OPTION_TARGET_DELTA=0.40
OPTION_TARGET_DTE=45

# Autonomous trading loop — dashboard starts scanning/trading (paper, per
# TRADING_MODE) on startup unless disabled here
AUTONOMOUS_TRADING_ENABLED=true
SCAN_INTERVAL_SECONDS=900
POSITION_CHECK_INTERVAL_SECONDS=120

# Dashboard — required; requests are rejected if unset
DASHBOARD_AUTH_TOKEN=

# Hourly Discord progress report — opt-in, only sends if DISCORD_WEBHOOK_URL
# (above) is configured; runs only during market hours
PROGRESS_REPORT_INTERVAL_SECONDS=3600

# Forex — opt-in (requires OANDA_API_KEY/OANDA_ACCOUNT_ID above). Trades the
# 24/5 forex session (Sun 5pm ET - Fri 5pm ET) independently of the equities
# loop. FOREX_PAIRS is a JSON array; leave unset for the default majors.
# FOREX_PAIRS=["EUR_USD","GBP_USD","USD_JPY","AUD_USD","USD_CAD","USD_CHF","NZD_USD"]
FOREX_CONFIDENCE_THRESHOLD=92
FOREX_RISK_PCT_PER_TRADE=0.02
FOREX_STOP_ATR_MULTIPLIER=1.5
FOREX_TAKE_PROFIT_R_MULTIPLE=2.0
FOREX_SCAN_INTERVAL_SECONDS=300
FOREX_POSITION_CHECK_INTERVAL_SECONDS=120
